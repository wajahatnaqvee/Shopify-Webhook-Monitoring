{
    "build": {
        "builder": "nixpacks",
        "buildCommand": "composer install --no-dev --optimize-autoloader && npm install && npm run build"
    },
    "deploy": {
        "startCommand": "php artisan migrate --force && php artisan queue:work --tries=3 & php artisan serve --host=0.0.0.0 --port=$PORT"
    },
    "mounts": [
        {
            "source": "storage",
            "target": "/app/storage"
        }
    ],
    "services": {
        "mysql": {
            "image": "mysql:8.0",
            "ports": [
                "3306"
            ]
        }
    },
    "envFile": [
        "DB_CONNECTION=mysql",
        "DB_HOST=${{MySQL.MYSQLHOST}}",
        "DB_PORT=${{MySQL.MYSQLPORT}}",
        "DB_DATABASE=${{MySQL.MYSQLDATABASE}}",
        "DB_USERNAME=${{MySQL.MYSQLUSER}}",
        "DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}",
        "APP_KEY=base64:PGg/StBg7QRKbn1KwzNLja7NikKsgR9afl1vc+3vhu0="
    ]
}
